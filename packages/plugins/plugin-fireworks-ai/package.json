  "description": "Fireworks AI provider plugin for Paperclip — configure and validate your Fireworks API key and model selections from the Paperclip settings UI.",
  "license": "MIT",
  "homepage": "https://github.com/Brandozip/paperclip",
  "bugs": {
    "url": "https://github.com/Brandozip/paperclip/issues"
  },
